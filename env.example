# CAMWATCH Environment Variables
# ================================
# STEP 1: Copy this file and rename it to:  .env
# STEP 2: Replace "your_api_key_here" with your actual Shodan API key
# STEP 3: Get your key at https://account.shodan.io
#
# IMPORTANT: Never commit .env to GitHub.
#            The .gitignore file will protect it — don't remove that entry.

SHODAN_API_KEY=your_shodan_key_here

# ── Email Alert Config (optional) ────────────────────────────────────────────
# Uses Gmail SMTP with an App Password (NOT your regular Gmail password).
# How to get one:
#   1. https://myaccount.google.com/security → enable 2-Step Verification
#   2. Search "App Passwords" → create one → paste the 16-char result below

ALERT_EMAIL_FROM=your_gmail@gmail.com
ALERT_EMAIL_PASSWORD=your_16char_app_password
ALERT_EMAIL_TO=recipient@example.com
