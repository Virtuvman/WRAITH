# CAMWATCH Environment Variables
# ================================
# STEP 1: Copy this file and rename it to:  .env
# STEP 2: Fill in values as needed for your environment
#
# IMPORTANT: Never commit .env to GitHub.
#            The .gitignore file will protect it — don't remove that entry.

# Data source API keys intentionally omitted for now.
# Add provider keys later if/when a source integration is enabled.

# ── Admin Metrics Access ─────────────────────────────────────────────────────
# Sidebar passphrase for unlocking the Admin Metrics panel in WRAITH.
# Trial recommendation: use a stronger temporary passphrase during peer pilot.
ADMIN_METRICS_PASSPHRASE=WRAITH_TRIAL_2026!

# ── Pilot Front-Door Access (App-Level Gate) ────────────────────────────────
# Enables full app password protection (separate from Admin Metrics unlock).
# Default recommendation for local dev: keep disabled unless explicitly testing gate behavior.
PILOT_ACCESS_ENABLED=false
# For local dev only (preferred on Streamlit Cloud: set in app Secrets).
PILOT_ACCESS_PASSWORD=WRAITH_TRIAL_2026!
# Lockout cooldown after 3 failed attempts.
PILOT_LOCKOUT_SECONDS=15

# ── Email Alert Config (optional) ────────────────────────────────────────────
# Uses Gmail SMTP with an App Password (NOT your regular Gmail password).
# How to get one:
#   1. https://myaccount.google.com/security → enable 2-Step Verification
#   2. Search "App Passwords" → create one → paste the 16-char result below

ALERT_EMAIL_FROM=your_gmail@gmail.com
ALERT_EMAIL_PASSWORD=your_16char_app_password
ALERT_EMAIL_TO=recipient@example.com

# ── Optional Splash Background (dashboard backdrop) ─────────────────────────
# Default is enabled in app code. Set false to disable.
ENABLE_SPLASH=true

# Optional explicit path. If blank/missing, app auto-falls back in this order:
# assets/wraith_splash.png -> WRAITH Logo.png -> wraith_logo.png -> wraith_logo.svg
SPLASH_BACKGROUND_PATH=assets/wraith_splash.png

# Dark overlay alpha for readability (0.0 to 0.9 recommended).
SPLASH_OVERLAY_ALPHA=0.35
